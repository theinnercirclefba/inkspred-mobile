{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      // Pin react/react-native to this app's own copies so hoisted deps
      // (@react-navigation/*, @expo/vector-icons) can't drift to the web app's
      // React 19 @types at the workspace root. These aliases are also consumed
      // by Expo's Metro resolver, so they must point at the runtime packages.
      "react": ["./node_modules/react"],
      "react/*": ["./node_modules/react/*"],
      "react-native": ["./node_modules/react-native"],
      "react-native/*": ["./node_modules/react-native/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": ["node_modules", ".expo-export-check"]
}
